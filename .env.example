# App
PORT=3000
NODE_ENV=development

# Database
# PostgreSQL is recommended. Some entities use PostgreSQL-specific types.
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=backend_user
DB_PASSWORD=change_me
DB_NAME=farmacia_centinela
DB_SYNCHRONIZE=true
DB_LOGGING=true
DB_SSL_MODE=false

# JWT auth
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_TTL=120s
JWT_REFRESH_TTL=300s
SKEW=5s
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Mailer / SMTP
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=change_me
MAIL_PASS=change_me

# S3 / MinIO
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_BUCKET=uvirtual
S3_FORCE_PATH_STYLE=true
S3_ACCESS_KEY=change_me
S3_SECRET_KEY=change_me
S3_PRESIGN_EXPIRES_SECONDS=3600

# AWS Polly
AWS_REGION=us-east-1

# AI services
GROQ_API_KEY=change_me

# BigBlueButton utilities, only needed if BBB helpers are used.
BBB_BASE_URL=
BBB_SECRET=
